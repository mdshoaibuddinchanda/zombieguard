# ─────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.so
.env
.venv/
venv/
env/
ENV/

# ─────────────────────────────────────────────
# IDE / OS
# ─────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# ─────────────────────────────────────────────
# Test / lint caches
# ─────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
build/
dist/
.ipynb_checkpoints/

# ─────────────────────────────────────────────
# Logs and temp files
# ─────────────────────────────────────────────
*.log
*.tmp
*.bak
detector_batch_output.txt

# ─────────────────────────────────────────────
# DATA — malware samples and large datasets
# Never push actual malware or large binary data.
# ─────────────────────────────────────────────

# Raw training data (synthetic malicious + benign ZIPs)
data/raw/

# Real malware samples from MalwareBazaar
data/real_world_validation/

# Real-world split directories (derived from real malware)
data/real_splits/

# Hard test set (contains real malware samples)
data/hard_test/

# Generalisation study archives (APK, RAR, 7z)
data/generalisation/

# Benign real-world ZIPs (large, regenerable)
data/benign_realworld/

# Operational download/resume state files
data/download_progress.json
data/timestamp_progress.json
data/benign_fp_progress.json
data/benign_fp_results.csv
data/benign_fp_summary.txt
data/realworld_splits.csv

# Feature extraction cache (auto-rebuilt by temporal_stability.py)
data/temporal_features_cache.csv

# ─────────────────────────────────────────────
# DATA — what IS tracked
# ─────────────────────────────────────────────

# Canonical processed feature matrix (source of truth for training)
# data/processed/features.csv  ← tracked
# data/processed/labels.csv    ← tracked
data/processed/*
!data/processed/features.csv
!data/processed/labels.csv

# MalwareBazaar timestamp metadata (no malware content, just dates)
# data/bazaar_timestamps.csv   ← tracked

# data/scripts/                ← tracked (all pipeline code)

# ─────────────────────────────────────────────
# MODELS — large binary files, not tracked
# ─────────────────────────────────────────────
models/*.pkl
models/*.joblib
models/*.pt

# ─────────────────────────────────────────────
# PAPER FIGURES
# CSV source tables → tracked (version-controlled data)
# PNG / PDF outputs → NOT tracked (regenerate with generate_all_figures.py)
# ─────────────────────────────────────────────
paper/figures/png/
paper/figures/pdf/

# Also exclude any stray image files at the flat figures/ level
paper/figures/*.png
paper/figures/*.pdf
paper/figures/*.svg
paper/figures/*.jpg
paper/figures/*.jpeg

# ─────────────────────────────────────────────
# ZIP files — never push sample data
# ─────────────────────────────────────────────
*.zip
*.rar
*.7z
*.apk
